{
  "name": "openbrain-scaffold",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"tests/**/*.ts\"",
    "audit:prompts": "tsx scripts/mock-prompt-audit/analyse.ts",
    "lighthouse": "tsx scripts/lighthouse.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,css}": "prettier --write",
    "tests/**/*.ts": "prettier --write",
    "e2e/**/*.ts": "prettier --write"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@sentry/react": "^10.48.0",
    "@supabase/auth-js": "^2.102.1",
    "@supabase/postgrest-js": "^2.102.1",
    "@supabase/realtime-js": "^2.18.1",
    "@tanstack/react-virtual": "^3.13.23",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "chrono-node": "^2.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "focus-trap-react": "^12.0.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.14.0",
    "mammoth": "^1.12.0",
    "node-html-parser": "^7.1.0",
    "pdfjs-dist": "^5.6.205",
    "posthog-js": "^1.372.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "stripe": "^22.1.0",
    "tailwind-merge": "^3.5.0",
    "web-push": "^3.6.7",
    "workbox-precaching": "^7.3.0",
    "workbox-routing": "^7.3.0",
    "workbox-strategies": "^7.3.0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "uuid": ">=14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@sentry/vite-plugin": "^5.2.0",
    "@softarc/sheriff-core": "^0.19.6",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "knip": "^6.4.0",
    "lighthouse": "^13.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^4.5.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.3"
  }
}
