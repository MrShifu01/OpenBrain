{
  "buildCommand": "npm run build",
  "crons": [
    { "path": "/api/cron/push?action=daily",  "schedule": "0 8 * * *" },
    { "path": "/api/cron/push?action=nudge",   "schedule": "0 10 * * *" },
    { "path": "/api/cron/push?action=expiry",  "schedule": "0 9 * * *" }
  ],
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/anthropic",        "destination": "/api/llm?provider=anthropic" },
    { "source": "/api/openai",           "destination": "/api/llm?provider=openai" },
    { "source": "/api/openrouter",       "destination": "/api/llm?provider=openrouter" },
    { "source": "/api/transcribe",       "destination": "/api/llm?action=transcribe" },
    { "source": "/api/delete-entry",     "destination": "/api/entries" },
    { "source": "/api/update-entry",     "destination": "/api/entries" },
    { "source": "/api/save-links",       "destination": "/api/capture?action=links" },
    { "source": "/api/export",           "destination": "/api/transfer" },
    { "source": "/api/import",           "destination": "/api/transfer" },
    { "source": "/api/notification-prefs", "destination": "/api/push?resource=prefs" },
    { "source": "/api/push-subscribe",   "destination": "/api/push?resource=subscribe" },
    { "source": "/api/pin",              "destination": "/api/user-data?resource=pin" },
    { "source": "/api/entry-brains",     "destination": "/api/entries?resource=entry-brains" },
    { "source": "/api/memory",           "destination": "/api/user-data?resource=memory" },
    { "source": "/api/activity",         "destination": "/api/user-data?resource=activity" },
    { "source": "/api/health",           "destination": "/api/user-data?resource=health" },
    { "source": "/api/vault",            "destination": "/api/user-data?resource=vault" },
    { "source": "/((?!api/|assets/).*)",  "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src 'self'; connect-src 'self' https://*.supabase.co https://api.anthropic.com https://api.openai.com https://openrouter.ai https://api.groq.com https://api.resend.com; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
