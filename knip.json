{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": [
    ".claude/**",
    ".smashOS/**",
    ".smash-os/**",
    ".worktrees/**",
    "graphify-out/**",
    "scripts/mock-prompt-audit/**",
    "supabase/functions/**",
    "dist/**",
    "e2e/**",
