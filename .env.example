# ── Supabase ──────────────────────────────────────────────────────────
# Project URL and keys from https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Client-side Supabase (VITE_ prefix = exposed to browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Anthropic (optional, for BYO key users) ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Default model ────────────────────────────────────────────────────
# Default: gemini-2.5-flash-lite (hardcoded in .env, override with VITE_MODEL)
# VITE_MODEL=gemini-2.5-flash-lite

# ── Feature Flags ─────────────────────────────────────────────────────
VITE_ENABLE_MULTI_BRAIN=false
# Set to true to make the knowledge graph visible to all users
VITE_FEATURE_GRAPH=false

# ── Upstash Redis (rate limiting) ─────────────────────────────────────
# From https://console.upstash.com — falls back to in-memory if not set
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Web Push / Notifications ──────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_SUBJECT=mailto:you@example.com
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
# Client-side VAPID public key (must match VAPID_PUBLIC_KEY above)
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# ── Resend (email invites) ────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM=Everion <noreply@yourdomain.com>

# ── Sentry (error monitoring) ─────────────────────────────────────────
# Get from https://sentry.io/settings/<org>/projects/<project>/keys/
# Omit or leave blank to disable Sentry in development
VITE_SENTRY_DSN=https://...@...ingest.sentry.io/...

# ── App URL ───────────────────────────────────────────────────────────
# Used for invite links. Auto-detected on Vercel via VERCEL_URL if not set.
APP_URL=https://everionmind.com


# ── Cron Security ─────────────────────────────────────────────────────
# HMAC secret for authenticating cron endpoint calls
CRON_SECRET=your-cron-secret

# ── Search ────────────────────────────────────────────────────────────
# Similarity threshold for vector search (default 0.3)
SEARCH_THRESHOLD=0.3

# ── Stripe ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_STARTER_ANNUAL_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
# Optional: override platform AI model per tier (defaults shown)
GEMINI_STARTER_MODEL=gemini-2.0-flash-lite
GEMINI_STARTER_CHAT_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-flash
GEMINI_PRO_CHAT_MODEL=gemini-2.5-flash

# ── Playwright e2e ─────────────────────────────────────────────────────────
# Real Supabase credentials Playwright signs in with via global-setup.ts.
# Put the actual values in .env.local (gitignored), never here.
E2E_ADMIN_EMAIL=admin@yourdomain.com
E2E_ADMIN_PASSWORD=your-admin-password
# Override if your dev server runs on a non-default port
# E2E_BASE_URL=http://localhost:5174
